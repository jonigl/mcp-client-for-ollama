# Optional Atlas Cloud credentials for hosted provider usage.
# This project does not auto-load .env files; export these values in your shell
# or save the API key in ~/.config/ollmcp/atlascloud.json before launching.

ATLAS_API_KEY=YOUR_ATLAS_API_KEY
ATLAS_BASE_URL=https://api.atlascloud.ai/v1
ATLAS_MODEL=openai/gpt-4o-mini
